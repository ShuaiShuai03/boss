{
  "name": "boss-helper",
  "displayName": "BossHelper",
  "version": "0.5.0",
  "private": true,
  "description": "Boss直聘助手, 皆在减少投递简历的麻烦, 和提高投递简历的效率,技术栈使用VIte + Vue3 + element-plus",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "postinstall": "wxt prepare",
    "check": "vue-tsc --noEmit",
    "build": "run-p build:chrome build:firefox build:edge",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "run-p zip:chrome zip:firefox zip:edge",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.76",
    "@nuxt/ui": "^4.9.0",
    "@vueuse/integrations": "^14.3.0",
    "ai": "^6.0.213",
    "codejar": "^4.3.0",
    "comctx": "^1.7.5",
    "partial-json": "^0.1.7",
    "serialize-error": "^13.0.1",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.4",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.21.1",
    "proto2api": "^0.0.8",
    "protobufjs": "^8.6.5",
    "sass": "^1.101.0",
    "ts-proto": "^2.11.8",
    "typescript": "^6.0.3",
    "uid": "^2.0.2",
    "vite-plugin-tailwind-shadowdom": "^1.1.1",
    "vue-tsc": "^3.3.5",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "@protobufjs/utf8": "^1.1.1",
    "axios": "^1.18.1",
    "brace-expansion": "^5.0.6",
    "defu": "^6.1.7",
    "fast-uri": "^4.0.0",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.6",
    "js-yaml": "^5.2.0",
    "minimatch": "^10.2.5",
    "node-forge": "^1.4.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "protobufjs": "^8.6.5",
    "rollup": "^4.62.2",
    "shell-quote": "^1.9.0",
    "tmp": "^0.2.7",
    "uuid": "^14.0.1",
    "vite": "^7.3.6",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix"
  }
}
